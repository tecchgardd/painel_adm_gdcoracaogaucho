{
  "expo": {
    "name": "Coração Gaúcho Admin",
    "slug": "coracao-gaucho-admin-mobile",
    "scheme": "coracaogauchoadmin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-oficial.jpeg",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/logo-oficial.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": true },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-oficial.jpeg",
        "backgroundColor": "#FFFFFF"
      }
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-camera"]
  }
}
